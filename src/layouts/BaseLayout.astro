---
import '../styles/global.css';
import { loadSiteConfig } from '../lib/site-config';
import { loadPrices } from '../lib/prices';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  robots?: string;
  /** ISO8601，头条时间因子 published */
  publishedTime?: string;
  /** ISO8601，头条时间因子 updated / lrDate */
  updatedTime?: string;
  /** 额外 JSON-LD 对象（会与站点级 Organization/WebSite 一并输出） */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const site = loadSiteConfig();
const prices = loadPrices();
const homeTdk = site.tdk.home;
const siteUrl = 'https://www.jrjrz.com';

const {
  title = homeTdk.title,
  description = homeTdk.description,
  keywords = homeTdk.keywords || '',
  robots = 'index, follow',
  publishedTime,
  updatedTime,
  jsonLd,
} = Astro.props;

const year = new Date().getFullYear();
const footer = site.footer;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '露梦AI Store',
  url: siteUrl,
  logo: `${siteUrl}/images/logo-favicon.png`,
  description: homeTdk.description,
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '露梦AI Store',
  url: siteUrl,
  description: homeTdk.description,
  inLanguage: 'zh-CN',
  publisher: {
    '@type': 'Organization',
    name: '露梦AI Store',
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo-favicon.png`,
    },
  },
};

const extraLd = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
const allJsonLd = [orgJsonLd, websiteJsonLd, ...extraLd];
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <!-- 站长平台站点验证 -->
    <meta name="baidu-site-verification" content="codeva-JS9ZFDURnr" />
    <meta name="bytedance-verification-code" content="8POzWa+n1Es76jXGDDGJ" />
    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-N5W444TK');
    </script>
    <!-- End Google Tag Manager -->
    <!-- Ahrefs Analytics -->
    <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="N0p/Xbdctxa3i3raDGf9/A" async></script>
    <!-- 今日头条自动收录 -->
    <script is:inline>
      (function(){
        var el = document.createElement("script");
        el.src = "https://lf1-cdn-tos.bytegoofy.com/goofy/ttzz/push.js?e49742c7c59be4a29e8856059cd4dd3f83ff71c46064c4456171dc9f519b599a3d72cd14f8a76432df3935ab77ec54f830517b3cb210f7fd334f50ccb772134a";
        el.id = "ttzz";
        var s = document.getElementsByTagName("script")[0];
        s.parentNode.insertBefore(el, s);
      })(window)
    </script>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="shortcut icon" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={robots} />
    {publishedTime && (
      <meta property="bytedance:published_time" content={publishedTime} />
    )}
    {updatedTime && (
      <>
        <meta property="bytedance:updated_time" content={updatedTime} />
        <meta property="bytedance:lrDate_time" content={updatedTime} />
      </>
    )}
    <title>{title}</title>
    {allJsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-N5W444TK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <nav class="top-nav">
      <div class="nav-inner">
        <a class="logo" href="/">
          <img class="logo-mark" src="/images/logo.jpg" alt="露梦AI Store LOGO" />
          <span>露梦AI Store</span>
        </a>
        <div class="nav-links">
          <a href="/#services">服务</a>
          <a href="/#how">流程</a>
          <a href="/blog/">博客</a>
          <a href="/#faq">FAQ</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer id="site-footer">
      <div class="container">
        <div class="footer-grid footer-fat">
          <div class="footer-brand">
            <a class="logo" href="/">
              <img class="logo-mark" src="/images/logo.jpg" alt="露梦AI Store LOGO" />
              <span style="color: var(--ink);">露梦AI Store</span>
            </a>
            <div class="footer-desc">{footer.brandDesc}</div>
          </div>
          {footer.columns.map((col) => (
            <div>
              <div class="footer-col-title">{col.title}</div>
              <ul class="footer-links">
                {col.links.map((link) => (
                  <li>
                    {link.action === 'qr' ? (
                      <a href="javascript:void(0)" onclick="openQrModal()">{link.text}</a>
                    ) : (
                      <a href={link.href}>{link.text}</a>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        {footer.seoLinks && footer.seoLinks.length > 0 && (
          <div class="footer-seo">
            <div class="footer-seo-title">{footer.seoTitle || '热门关键词'}</div>
            <div class="footer-seo-links">
              {footer.seoLinks.map((l) => (
                <a href={l.href}>{l.text}</a>
              ))}
            </div>
          </div>
        )}

        <div class="footer-bottom">
          <div>&copy; {year} 露梦AI Store。{footer.copyright}</div>
          <div class="footer-badges">
            <div class="fbadge">{prices.payment.label}</div>
            <div class="fbadge">SSL 加密</div>
          </div>
        </div>
      </div>
    </footer>

    <div class="qr-modal" id="qrModal" aria-hidden="true">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
        <button class="modal-close" type="button" onclick="closeQrModal()" aria-label="关闭">×</button>
        <div class="section-label" id="modalTitle" style="text-align:center;">添加客服微信</div>
        <img class="qr-image" src="/images/qrcode.png" alt="客服微信二维码" />
      </div>
    </div>

    <!-- 博客等页面可在正文使用 data-price / data-price-text，与服务页同一 prices.json -->
    <script is:inline src="/js/apply-prices.js"></script>
    <script is:inline>
      var revealItems = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        var revealObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
        revealItems.forEach(function (item) { revealObserver.observe(item); });
      } else {
        revealItems.forEach(function (item) { item.classList.add('in-view'); });
      }

      function openQrModal() {
        var modal = document.getElementById('qrModal');
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
      }
      function closeQrModal() {
        var modal = document.getElementById('qrModal');
        modal.classList.remove('active');
        modal.setAttribute('aria-hidden', 'true');
      }
      document.getElementById('qrModal').addEventListener('click', function (event) {
        if (event.target === event.currentTarget) closeQrModal();
      });

      document.querySelectorAll('.faq-item').forEach(function (item) {
        item.querySelector('.faq-q')?.addEventListener('click', function () {
          item.classList.toggle('active');
        });
      });

      function copySessionUrl(target) {
        var text = 'chatgpt.com/api/auth/session';
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text);
          var old = target.textContent;
          target.textContent = '已复制：' + text;
          window.setTimeout(function () { target.textContent = old; }, 1400);
        }
      }
    </script>
  </body>
</html>
