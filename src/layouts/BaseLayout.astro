---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const { title = '露梦的博客', description = '记录 AI、技术与思考' } = Astro.props;
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <nav class="top-nav">
      <div class="nav-inner">
        <a class="logo" href="/"><span class="logo-mark"></span><span>露梦的博客</span></a>
        <div class="nav-links">
          <a href="/">首页</a>
          <a href="/blog">文章</a>
          <a href="/about">关于</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <a class="logo" href="/"><span class="logo-mark"></span><span>露梦的博客</span></a>
            <p class="footer-desc">记录 AI、技术与日常思考。由 Astro 驱动，部署在 Cloudflare Pages。</p>
          </div>
          <div>
            <div class="footer-col-title">导航</div>
            <ul class="footer-links">
              <li><a href="/">首页</a></li>
              <li><a href="/blog">全部文章</a></li>
              <li><a href="/about">关于</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-col-title">更多</div>
            <ul class="footer-links">
              <li><a href="/admin/">写作后台</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <div>&copy; {year} 露梦的博客</div>
          <div class="footer-badges">
            <span class="fbadge">Astro</span>
            <span class="fbadge">Cloudflare</span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
