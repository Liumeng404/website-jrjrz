---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = '露梦AI Store | ChatGPT Plus / Claude / SuperGrok 订阅代充',
  description = '露梦AI Store 提供 ChatGPT Plus、Claude Pro、SuperGrok 订阅代充服务。支持微信/支付宝，原账号开通，无需账号密码。'
} = Astro.props;
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <!-- 站长验证：搜狗要求验证码 meta 尽量靠前（紧跟 charset） -->
    <meta name="sogou_site_verification" content="UqxmzjbV52" />
    <meta name="baidu-site-verification" content="codeva-JS9ZFDURnr" />
    <meta name="bytedance-verification-code" content="8POzWa+n1Es76jXGDDGJ" />
    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-N5W444TK');
    </script>
    <!-- End Google Tag Manager -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-N5W444TK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- 顶部导航（与首页 HTML 一致） -->
    <nav class="top-nav">
      <div class="nav-inner">
        <a class="logo" href="/">
          <img class="logo-mark" src="/images/logo.jpg" alt="露梦AI Store LOGO" />
          <span>露梦AI Store</span>
        </a>
        <div class="nav-links">
          <a href="/#services">服务</a>
          <a href="/#how">流程</a>
          <a href="/blog/">博客</a>
          <a href="/#faq">FAQ</a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- 页脚（与首页 HTML 一致） -->
    <footer>
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a class="logo" href="/">
              <img class="logo-mark" src="/images/logo.jpg" alt="露梦AI Store LOGO" />
              <span style="color: var(--ink);">露梦AI Store</span>
            </a>
            <div class="footer-desc">专注 AI 订阅服务代充，为国内用户提供更便捷的 AI 工具访问方式。</div>
          </div>
          <div>
            <div class="footer-col-title">服务</div>
            <ul class="footer-links">
              <li><a href="https://www.jrjrz.com/chatgpt.html">ChatGPT Plus</a></li>
              <li><a href="https://www.jrjrz.com/claude.html">Claude Pro</a></li>
              <li><a href="https://www.jrjrz.com/grok.html">SuperGrok</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-col-title">内容</div>
            <ul class="footer-links">
              <li><a href="/blog/">博客文章</a></li>
              <li><a href="/#how">充值流程</a></li>
              <li><a href="/#faq">常见问题</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-col-title">支持</div>
            <ul class="footer-links">
              <li><a href="javascript:void(0)" onclick="openQrModal()">联系客服</a></li>
              <li><a href="/#services">查看套餐</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <div>&copy; {year} 露梦AI Store。本平台提供订阅代付与开通协助服务，与 OpenAI / Anthropic / xAI 无官方关联。</div>
          <div class="footer-badges">
            <div class="fbadge">微信支付</div>
            <div class="fbadge">SSL 加密</div>
          </div>
        </div>
      </div>
    </footer>

    <!-- 微信二维码弹窗 -->
    <div class="qr-modal" id="qrModal" aria-hidden="true">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
        <button class="modal-close" type="button" onclick="closeQrModal()" aria-label="关闭">×</button>
        <div class="section-label" id="modalTitle" style="text-align:center;">添加客服微信</div>
        <img class="qr-image" src="/images/qrcode.png" alt="客服微信二维码" />
      </div>
    </div>

    <script is:inline>
      // 滚动入场动画
      var revealItems = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        var revealObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
        revealItems.forEach(function (item) { revealObserver.observe(item); });
      } else {
        revealItems.forEach(function (item) { item.classList.add('in-view'); });
      }

      // 二维码弹窗
      function openQrModal() {
        var modal = document.getElementById('qrModal');
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
      }
      function closeQrModal() {
        var modal = document.getElementById('qrModal');
        modal.classList.remove('active');
        modal.setAttribute('aria-hidden', 'true');
      }
      document.getElementById('qrModal').addEventListener('click', function (event) {
        if (event.target === event.currentTarget) closeQrModal();
      });

      // FAQ 折叠
      document.querySelectorAll('.faq-item').forEach(function (item) {
        item.querySelector('.faq-q')?.addEventListener('click', function () {
          item.classList.toggle('active');
        });
      });

      // 复制 Session URL
      function copySessionUrl(target) {
        var text = 'chatgpt.com/api/auth/session';
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text);
          var old = target.textContent;
          target.textContent = '已复制：' + text;
          window.setTimeout(function () { target.textContent = old; }, 1400);
        }
      }
    </script>
  </body>
</html>
