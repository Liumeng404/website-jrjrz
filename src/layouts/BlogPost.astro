---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
  };
}
const { frontmatter } = Astro.props;

const dateFmt = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const pubStr = dateFmt.format(frontmatter.pubDate);
const updStr = frontmatter.updatedDate ? dateFmt.format(frontmatter.updatedDate) : '';
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article>
    <header class="article-header">
      <h1>{frontmatter.title}</h1>
      <div class="article-meta">
        <span>发布于 {pubStr}</span>
        {updStr && <span class="updated">· 更新于 {updStr}</span>}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <a href="/blog" class="back-link">← 返回文章列表</a>
  </article>
</BaseLayout>
