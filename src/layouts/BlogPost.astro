---
interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    image?: string;
    tags?: string[];
    author?: string;
  };
}
const { frontmatter } = Astro.props;

const dateFmt = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const pubStr = dateFmt.format(frontmatter.pubDate);
const updStr = frontmatter.updatedDate ? dateFmt.format(frontmatter.updatedDate) : '';
const tags = frontmatter.tags || [];
const author = frontmatter.author || '露梦';
---

<article>
  <header class="article-header">
    {tags.length > 0 && (
      <div class="article-tags">
        {tags.map((tag) => <span class="article-tag">{tag}</span>)}
      </div>
    )}
    <h1 class="article-title">{frontmatter.title}</h1>
    <div class="article-meta">
      <div class="article-author-info">
        <span>👤</span>
        <span>{author}</span>
      </div>
      <span>📅 {pubStr}</span>
      {updStr && <span>· 更新于 {updStr}</span>}
    </div>
  </header>

  {frontmatter.image && (
    <div class="article-cover">
      <img src={frontmatter.image} alt={frontmatter.title} />
    </div>
  )}

  <div class="prose">
    <slot />
  </div>

  <a href="/blog/" class="back-link">← 返回文章列表</a>
</article>
