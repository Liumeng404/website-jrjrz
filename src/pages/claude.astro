---
import ProductLayout from '../layouts/ProductLayout.astro';
import { loadPrices } from '../lib/prices';

const prices = loadPrices();
const p = prices.claude;
const pay = prices.payment;
const policy = prices.policy;
---

<ProductLayout page="claude">
  <nav class="sub-nav">
    <div class="nav-inner">
      <div class="sub-title">Claude Pro 原账号订阅</div>
      <div class="sub-actions">
        <a href="#plans">套餐</a>
        <a href="#how">怎么开通</a>
        <a class="pill small" href="javascript:void(0)" onclick="openQrModal()">联系客服</a>
      </div>
    </div>
  </nav>

  <main>
    <section class="product-hero">
      <div class="container">
        <div class="product-logo claude">
          <img src="/images/claude-color.svg" alt="Claude Logo" />
        </div>
        <div class="product-eyebrow">Claude Pro 代充值 · 长文档 · 代码 · 写作</div>
        <h1><span class="gradient-text">Claude Pro</span> 代充值</h1>
        <p class="product-subtitle">
          适合长上下文阅读、代码生成、学术写作和深度思考任务。支持{pay.label}，开通到您的原账号。
        </p>
        <div class="note-pill">Claude 使用环境要求更严格 · 下单前建议先确认账号状态 · 月付 ¥{p.pro}</div>
        <div class="hero-actions">
          <a class="pill" href="#plans">查看套餐</a>
          <button class="pill secondary" type="button" onclick="openQrModal()">联系客服</button>
        </div>
      </div>
    </section>

    <section class="section-pad section-soft" id="plans">
      <div class="container">
        <div class="section-label reveal">Claude 订阅方案</div>
        <h2 class="section-title reveal">从 Pro 到 Max，覆盖不同使用量</h2>
        <p class="section-sub reveal">Claude Pro 当前可咨询开通；Max 档位按库存和账号状态确认，到货前可先登记需求。</p>

        <div class="plans-grid">
          <article class="plan-card reveal" style="--delay: 80ms;">
            <div class="plan-badge">高频选择</div>
            <h3 class="plan-name">Claude Pro</h3>
            <div class="plan-origin">官方参考价 $20/月</div>
            <div class="plan-price">
              <span class="label">月付</span>
              <span class="num">¥{p.pro}</span>
              <span class="unit">/ 月</span>
            </div>
            <ul class="feature-list">
              <li>更多 Claude 使用量</li>
              <li>适合长文档、写作、代码生成和研究任务</li>
              <li>支持 Projects 项目整理与上下文管理</li>
              <li>可访问更多 Claude 模型能力</li>
              <li>开通到您的原账号，不需要账号密码</li>
              <li>下单前可先确认账号和使用环境</li>
            </ul>
            <button class="plan-cta" type="button" onclick="openQrModal()">立即咨询</button>
            <div class="plan-note">原账号订阅 · 账号状态先确认</div>
          </article>

          <article class="plan-card muted reveal" style="--delay: 160ms;">
            <div class="plan-badge">暂无货</div>
            <h3 class="plan-name">Claude Max 5x</h3>
            <div class="plan-origin">官方参考价 $100/月</div>
            <div class="plan-price">
              <span class="label">状态</span>
              <span class="num">登记</span>
              <span class="unit">需求</span>
            </div>
            <ul class="feature-list">
              <li>约为 Pro 更高档位的使用量</li>
              <li>适合更高频的长文本和代码任务</li>
              <li>高峰时段拥有更高使用空间</li>
              <li>包含 Pro 的主要能力</li>
              <li>库存和开通方式需按账号确认</li>
              <li>可联系客服登记到货提醒</li>
            </ul>
            <button class="plan-cta disabled" type="button" disabled>暂无货</button>
            <div class="plan-note">到货时间待定，可先联系客服登记</div>
          </article>

          <article class="plan-card muted reveal" style="--delay: 240ms;">
            <div class="plan-badge">暂无货</div>
            <h3 class="plan-name">Claude Max 20x</h3>
            <div class="plan-origin">官方参考价 $200/月</div>
            <div class="plan-price">
              <span class="label">状态</span>
              <span class="num">登记</span>
              <span class="unit">需求</span>
            </div>
            <ul class="feature-list">
              <li>面向极高频专业用户</li>
              <li>适合大规模文档、代码库和复杂推理任务</li>
              <li>更高额度，适合长期重度工作流</li>
              <li>包含 Pro 的主要能力</li>
              <li>账号与库存要求更严格</li>
              <li>建议先联系客服确认是否可开通</li>
            </ul>
            <button class="plan-cta disabled" type="button" disabled>暂无货</button>
            <div class="plan-note">到货时间待定，可先联系客服登记</div>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad section-dark" id="how">
      <div class="container">
        <div class="section-label reveal">开通流程</div>
        <h2 class="section-title reveal">三步完成 Claude Pro 开通</h2>
        <p class="section-sub reveal">Claude 对账号环境更敏感，建议先确认账号状态后再付款。</p>
        <div class="steps-grid">
          <article class="step-card reveal" style="--delay: 80ms;">
            <div class="step-num">01</div>
            <h3>联系客服确认账号</h3>
            <p>说明您要开通 Claude Pro，并告知账号当前状态。客服会先确认是否适合操作。</p>
          </article>
          <article class="step-card reveal" style="--delay: 160ms;">
            <div class="step-num">02</div>
            <h3>获取 Organization ID</h3>
            <p>登录 Claude 后进入账号设置页面，复制 Organization ID 等开通所需信息。</p>
            <button class="code-chip" type="button" onclick="copyText(this, 'claude.ai/settings/account')">
              claude.ai/settings/account
            </button>
          </article>
          <article class="step-card reveal" style="--delay: 240ms;">
            <div class="step-num">03</div>
            <h3>提交信息并核验</h3>
            <p>提交必要信息后等待处理。完成后刷新 Claude，看到 Pro 标识或权益生效即可。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="container">
        <div class="section-label reveal">服务保障</div>
        <h2 class="section-title reveal">安全 · 快速 · 透明</h2>
        <div class="trust-grid">
          <article class="trust-card reveal">
            <div class="trust-num">01</div>
            <h3>{policy.noPassword}</h3>
            <p>只提交开通所需的信息，不索要您的登录密码。</p>
          </article>
          <article class="trust-card reveal">
            <div class="trust-num">02</div>
            <h3>使用环境提醒</h3>
            <p>Claude 对地区和网络环境更敏感，我们会提前提示相关风险。</p>
          </article>
          <article class="trust-card reveal">
            <div class="trust-num">03</div>
            <h3>失败退款</h3>
            <p>若因账号状态或平台规则无法完成，未成功部分按约定退款。详见 <a href="/refund/">退款与售后</a>。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad section-soft" id="faq">
      <div class="container">
        <div class="section-label reveal">常见问题</div>
        <h2 class="section-title reveal">Claude Pro 代充常见问题</h2>
        <div class="faq-list">
          <div class="faq-item active">
            <div class="faq-q">国内怎么订阅 Claude Pro？大陆可以充值吗？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              Claude 官方支付对国内用户不友好，且账号环境要求较严格。可以先联系露梦AI Store 确认账号状态，再按流程安排开通。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Claude 和 ChatGPT 哪个好？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              Claude 更适合长文档处理、代码审阅、学术写作和复杂文本推理；ChatGPT 更适合通用问答、联网搜索、图像生成和生态工具。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Claude Pro 和 ChatGPT Plus 哪个更值得买？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              如果您主要处理长文档、代码和写作，Claude Pro 更值得优先考虑；如果更重视图像生成、联网搜索和多工具生态，可以选择 ChatGPT Plus。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Claude Pro 月付多少钱？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              当前 Claude Pro 月付价格为 ¥{p.pro}。Max 档位暂按库存和账号状态确认，页面展示为登记需求。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">支持哪些付款方式？<span class="faq-icon">+</span></div>
            <div class="faq-a">{pay.faq}</div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Claude 使用时会不会受限？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              Claude 对访问环境较敏感。充值本身不需要您的密码，但使用时建议保持稳定网络环境，避免因平台风控造成账号限制。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Claude Pro 的长上下文适合什么场景？<span class="faq-icon">+</span></div>
            <div class="faq-a">适合阅读长文档、分析研究报告、梳理代码库、整理学术资料、做长篇写作和复杂逻辑推理。</div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-banner" id="contact">
      <div class="container">
        <div class="section-label">立即开始</div>
        <h2 class="section-title">确认账号状态，安排 Claude 开通</h2>
        <p class="section-sub">把账号状态和使用环境发给客服，确认可操作后再付款。</p>
        <div class="hero-actions">
          <button class="pill" type="button" onclick="openQrModal()">添加微信</button>
          <a class="pill secondary" href="#plans">查看套餐</a>
        </div>
      </div>
    </section>
  </main>
</ProductLayout>
