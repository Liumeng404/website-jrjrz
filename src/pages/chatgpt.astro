  <script slot="scripts" is:inline>
    (function () {
      var target = document.getElementById('typewriterText');
      if (!target) return;

      var phrases = ['ChatGPT Plus', 'ChatGPT 5x Pro', 'ChatGPT 20x Pro'];
      var prefersReducedMotion =
        window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        target.textContent = phrases[0];
        return;
      }

      var phraseIndex = 0;
      var deleting = false;

      function typeNext() {
        var phrase = phrases[phraseIndex];
        var current = target.textContent || '';

        if (!deleting) {
          target.textContent = phrase.slice(0, current.length + 1);
        } else {
          target.textContent = phrase.slice(0, Math.max(0, current.length - 1));
        }

        var delay = deleting ? 58 : 92;

        if (!deleting && target.textContent === phrase) {
          deleting = true;
          delay = 1450;
        } else if (deleting && target.textContent === '') {
          deleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          delay = 320;
        }

        window.setTimeout(typeNext, delay);
      }

      window.setTimeout(typeNext, 420);
    })();

    document.querySelectorAll('.faq-item').forEach(function (item) {
      var button = item.querySelector('.faq-q');
      if (!button || button.tagName !== 'BUTTON') return;
      button.addEventListener('click', function () {
        window.setTimeout(function () {
          button.setAttribute(
            'aria-expanded',
            item.classList.contains('active') ? 'true' : 'false'
          );
        }, 0);
      });
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && typeof closeQrModal === 'function') closeQrModal();
    });
  </script>
