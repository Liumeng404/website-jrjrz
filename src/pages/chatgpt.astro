---
import ProductLayout from '../layouts/ProductLayout.astro';
import { loadPrices } from '../lib/prices';

const prices = loadPrices();
const p = prices.chatgpt;
const pay = prices.payment;
const policy = prices.policy;
---

<ProductLayout page="chatgpt">
  <nav class="sub-nav">
    <div class="nav-inner">
      <div class="sub-title">ChatGPT Plus 原账号订阅</div>
      <div class="sub-actions">
        <a href="#plans">套餐</a>
        <a href="#how">怎么开通</a>
        <a class="pill small" href="javascript:void(0)" onclick="openQrModal()">联系客服</a>
      </div>
    </div>
  </nav>

  <main>
    <section class="product-hero">
      <div class="container">
        <div class="product-logo openai">
          <img src="/images/openai.svg" alt="OpenAI Logo" />
        </div>
        <div class="product-eyebrow">ChatGPT Plus 代充值 · {pay.eyebrow} · {policy.ownAccount}</div>
        <h1><span class="gradient-text">ChatGPT Plus</span> 代充值</h1>
        <p class="product-subtitle">
          面向国内用户的 ChatGPT 订阅开通服务。无需境外信用卡，按流程提交必要信息，开通到您的原账号。
        </p>
        <div class="note-pill">官方参考价 $20/月 · ChatGPT Plus ¥{p.plus}/月</div>
        <div class="hero-actions">
          <a class="pill" href="#plans">查看套餐</a>
          <button class="pill secondary" type="button" onclick="openQrModal()">联系客服</button>
        </div>
      </div>
    </section>

    <section class="section-pad section-soft" id="plans">
      <div class="container">
        <div class="section-label reveal">ChatGPT 订阅方案</div>
        <h2 class="section-title reveal">三档方案，覆盖不同使用强度</h2>
        <p class="section-sub reveal">均按原账号订阅处理。Plus 适合日常高频使用，Pro 档位适合更高额度和更重任务。</p>

        <div class="plans-grid">
          <article class="plan-card reveal" style="--delay: 80ms;">
            <div class="plan-badge">最受欢迎</div>
            <h3 class="plan-name">ChatGPT Plus</h3>
            <div class="plan-origin">官方参考价 $20/月</div>
            <div class="plan-price">
              <span class="label">月付</span>
              <span class="num">¥{p.plus}</span>
              <span class="unit">/ 月</span>
            </div>
            <ul class="feature-list">
              <li>访问 ChatGPT 高阶模型与高级工具</li>
              <li>支持文件上传、数据分析和联网搜索</li>
              <li>支持图像生成与常用创作任务</li>
              <li>适合写作、学习、办公和编程辅助</li>
              <li>开通到您的原账号，不提供共享账号</li>
              <li>自助流程，按提示提交 Session 信息</li>
            </ul>
            <button class="plan-cta" type="button" onclick="openQrModal()">联系客服购买</button>
            <div class="plan-note">无需密码 · 原账号开通 · 未成功全额退款</div>
          </article>

          <article class="plan-card reveal" style="--delay: 160ms;">
            <div class="plan-badge">效率之选</div>
            <h3 class="plan-name">ChatGPT Pro 5x</h3>
            <div class="plan-origin">官方参考价 $100/月</div>
            <div class="plan-price">
              <span class="label">月付</span>
              <span class="num">¥{p.pro5x}</span>
              <span class="unit">/ 月</span>
            </div>
            <ul class="feature-list">
              <li>相比 Plus 拥有更高使用额度</li>
              <li>适合重度编程、资料处理和高频问答</li>
              <li>提高高阶模型与高级工具使用空间</li>
              <li>适合个人效率提升和专业工作流</li>
              <li>人工确认账号状态后安排开通</li>
              <li>金额较高，建议付款前先联系客服确认</li>
            </ul>
            <button class="plan-cta" type="button" onclick="openQrModal()">联系客服购买</button>
            <div class="plan-note">人工处理 · 先确认账号状态</div>
          </article>

          <article class="plan-card reveal" style="--delay: 240ms;">
            <div class="plan-badge">旗舰版</div>
            <h3 class="plan-name">ChatGPT Pro 20x</h3>
            <div class="plan-origin">官方参考价 $200/月</div>
            <div class="plan-price">
              <span class="label">月付</span>
              <span class="num">¥{p.pro20x}</span>
              <span class="unit">/ 月</span>
            </div>
            <ul class="feature-list">
              <li>面向更重度的专业 AI 使用场景</li>
              <li>适合大批量内容、代码和复杂任务处理</li>
              <li>更高额度，降低高峰期额度焦虑</li>
              <li>适合团队核心成员或高价值个人工作流</li>
              <li>下单前需确认账号与交付方式</li>
              <li>由客服按账号状态跟进处理</li>
            </ul>
            <button class="plan-cta" type="button" onclick="openQrModal()">联系客服购买</button>
            <div class="plan-note">高额方案 · 建议先咨询再付款</div>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad section-dark" id="how">
      <div class="container">
        <div class="section-label reveal">开通流程</div>
        <h2 class="section-title reveal">三步完成 ChatGPT 订阅开通</h2>
        <p class="section-sub reveal">流程以 ChatGPT Plus 为例，全程不需要提供账号密码。</p>
        <div class="steps-grid">
          <article class="step-card reveal" style="--delay: 80ms;">
            <div class="step-num">01</div>
            <h3>下单并获取卡密</h3>
            <p>选择对应套餐，通过{pay.label}完成付款。付款后保留发货内容里的卡密或充值凭证。</p>
          </article>
          <article class="step-card reveal" style="--delay: 160ms;">
            <div class="step-num">02</div>
            <h3>复制 Session 内容</h3>
            <p>登录 ChatGPT 后访问指定地址，复制页面返回的 JSON 文本。</p>
            <button class="code-chip" type="button" onclick="copyText(this, 'chatgpt.com/api/auth/session')">
              chatgpt.com/api/auth/session
            </button>
          </article>
          <article class="step-card reveal" style="--delay: 240ms;">
            <div class="step-num">03</div>
            <h3>提交充值并核验</h3>
            <p>在自助页面提交卡密与 Session 信息。处理完成后刷新 ChatGPT，看到 Plus 标识即表示开通成功。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="container">
        <div class="section-label reveal">服务保障</div>
        <h2 class="section-title reveal">安全 · 快速 · 透明</h2>
        <div class="trust-grid">
          <article class="trust-card reveal">
            <div class="trust-num">01</div>
            <h3>{policy.noPassword}</h3>
            <p>按平台流程提交必要信息，不索要您的登录密码。</p>
          </article>
          <article class="trust-card reveal">
            <div class="trust-num">02</div>
            <h3>原账号订阅</h3>
            <p>会员开通在您的原账号，不提供共享账号，减少隐私风险。</p>
          </article>
          <article class="trust-card reveal">
            <div class="trust-num">03</div>
            <h3>失败退款</h3>
            <p>若因账号状态或平台限制无法完成，未成功部分按约定退款。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad section-soft" id="faq">
      <div class="container">
        <div class="section-label reveal">常见问题</div>
        <h2 class="section-title reveal">ChatGPT Plus 代充常见问题</h2>
        <div class="faq-list">
          <div class="faq-item active">
            <div class="faq-q">国内怎么订阅 ChatGPT Plus？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              国内用户如果没有可用的境外支付方式，可以通过露梦AI Store 协助完成订阅开通。您只需按流程付款并提交必要信息，不需要提供账号密码。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">没有信用卡怎么开通 ChatGPT Plus？<span class="faq-icon">+</span></div>
            <div class="faq-a">可以使用{pay.label}人民币付款，不需要境外信用卡、PayPal 或外币扣款。</div>
          </div>
          <div class="faq-item">
            <div class="faq-q">ChatGPT Plus 一个月多少钱？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              露梦AI Store 当前 ChatGPT Plus 月付价格为 ¥{p.plus}。Pro 5x 与 Pro 20x 属于更高额度方案，价格分别为 ¥{p.pro5x}/月、¥{p.pro20x}/月。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">支持哪些付款方式？<span class="faq-icon">+</span></div>
            <div class="faq-a">{pay.faq}</div>
          </div>
          <div class="faq-item">
            <div class="faq-q">ChatGPT Plus 值得买吗？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              如果您需要高频使用 GPT 高阶模型、文件分析、联网搜索、图像生成或编程辅助，Plus 通常比免费版更稳定。轻度聊天用户可以先使用免费版。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">ChatGPT 订阅失败怎么办？<span class="faq-icon">+</span></div>
            <div class="faq-a">如因账号状态、订阅未到期或平台规则导致无法开通，我们会协助排查；未成功部分按约定退款。</div>
          </div>
          <div class="faq-item">
            <div class="faq-q">ChatGPT Pro 和 Plus 有什么区别？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              Plus 适合大多数个人用户；Pro 档位适合更高额度、更重任务和更密集的专业使用。具体是否需要 Pro，建议先说明使用场景再确认。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Claude 和 ChatGPT 应该选哪个？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              ChatGPT 更适合通用问答、联网搜索、图像生成和生态工具；Claude 更适合长文档、写作、代码审阅和复杂文本处理。
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-banner" id="contact">
      <div class="container">
        <div class="section-label">立即开始</div>
        <h2 class="section-title">确认账号状态，安排 ChatGPT 开通</h2>
        <p class="section-sub">把您要开的套餐、账号当前订阅状态发给客服，确认后再付款。</p>
        <div class="hero-actions">
          <button class="pill" type="button" onclick="openQrModal()">添加微信</button>
          <a class="pill secondary" href="#plans">查看套餐</a>
        </div>
      </div>
    </section>
  </main>
</ProductLayout>
