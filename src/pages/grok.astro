---
import ProductLayout from '../layouts/ProductLayout.astro';
import { loadPrices } from '../lib/prices';

const prices = loadPrices();
const g = prices.grok;
const pay = prices.payment;
const policy = prices.policy;
---

<ProductLayout page="grok">
  <nav class="sub-nav">
    <div class="nav-inner">
      <div class="sub-title">SuperGrok 原账号订阅</div>
      <div class="sub-actions">
        <a href="#plans">套餐</a>
        <a href="#how">怎么开通</a>
        <a class="pill small" href="javascript:void(0)" onclick="openQrModal()">联系客服</a>
      </div>
    </div>
  </nav>

  <main>
    <section class="product-hero">
      <div class="container">
        <div class="product-logo grok">
          <img src="/images/grok.svg" alt="Grok Logo" />
        </div>
        <div class="product-eyebrow">Grok 会员代充值 · {pay.eyebrow} · 原账号直充</div>
        <h1><span class="gradient-text">SuperGrok</span> 代充值</h1>
        <p class="product-subtitle">
          开通到您的自用账号，无需处理境外支付与绑卡流程，全程无需提供账号密码。
        </p>
        <div class="note-pill">
          月付 ¥{g.monthly} · 双月 ¥{g.bimonthly} · 双月方案立省 ¥{g.bimonthly_save}
        </div>
        <div class="hero-actions">
          <a class="pill" href="#plans">查看套餐</a>
          <button class="pill secondary" type="button" onclick="openQrModal()">联系客服</button>
        </div>
      </div>
    </section>

    <section class="section-pad section-soft" id="plans">
      <div class="container">
        <div class="section-label reveal">SuperGrok 订阅方案</div>
        <h2 class="section-title reveal">月付灵活，双月更省心</h2>
        <p class="section-sub reveal">均为直充自用账号，不提供共享账号。首次尝试可选择月付，稳定使用优先选择双月套餐。</p>

        <div class="plans-grid two-up">
          <article class="plan-card reveal" style="--delay: 80ms;">
            <div class="plan-badge">灵活体验</div>
            <h3 class="plan-name">SuperGrok 月付</h3>
            <div class="plan-origin">适合初次体验或短期使用</div>
            <div class="plan-price">
              <span class="label">1 个月</span>
              <span class="num">¥{g.monthly}</span>
              <span class="unit">/ 月</span>
            </div>
            <ul class="feature-list">
              <li>开通到您的自用账号，账号归属不变</li>
              <li>获得对应周期的 SuperGrok 会员权益</li>
              <li>无需境外信用卡或外币支付</li>
              <li>支持{pay.label}</li>
              <li>开通过程无需提交账号密码</li>
              <li>遇到异常可联系人工客服处理</li>
            </ul>
            <button class="plan-cta" type="button" onclick="openQrModal()">联系客服购买</button>
            <div class="plan-note">原账号直充 · 无需密码 · 人工支持</div>
          </article>

          <article class="plan-card reveal" style="--delay: 160ms;">
            <div class="plan-badge">推荐选择</div>
            <h3 class="plan-name">SuperGrok 双月</h3>
            <div class="plan-origin">连续两个月，相比月付节省 ¥{g.bimonthly_save}</div>
            <div class="plan-price">
              <span class="label">2 个月</span>
              <span class="num">¥{g.bimonthly}</span>
              <span class="unit">/ 双月</span>
            </div>
            <ul class="feature-list">
              <li>一次开通两个月，减少续费操作</li>
              <li>相比连续两次月付节省 ¥{g.bimonthly_save}</li>
              <li>直充自己的账号，使用更安心</li>
              <li>无需处理绑卡或付款失败问题</li>
              <li>支持{pay.label}便捷下单</li>
              <li>异常情况由人工客服协助跟进</li>
            </ul>
            <button class="plan-cta" type="button" onclick="openQrModal()">购买双月方案</button>
            <div class="plan-note">推荐方案 · 更省心 · 更划算</div>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad section-dark" id="how">
      <div class="container">
        <div class="section-label reveal">开通流程</div>
        <h2 class="section-title reveal">三步安排 SuperGrok 开通</h2>
        <p class="section-sub reveal">先确认套餐与账号情况，再进行付款和开通；流程无需提交登录密码。</p>
        <div class="steps-grid">
          <article class="step-card reveal" style="--delay: 80ms;">
            <div class="step-num">01</div>
            <h3>选择套餐</h3>
            <p>选择月付或双月方案，添加客服说明您的开通需求，确认可操作后再下单。</p>
          </article>
          <article class="step-card reveal" style="--delay: 160ms;">
            <div class="step-num">02</div>
            <h3>完成付款</h3>
            <p>使用{pay.label}完成付款，按客服提示提供开通所需信息，不需要提交账号密码。</p>
          </article>
          <article class="step-card reveal" style="--delay: 240ms;">
            <div class="step-num">03</div>
            <h3>核验权益</h3>
            <p>开通处理完成后登录 Grok 检查会员权益。如遇异常，可联系人工客服继续处理。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="container">
        <div class="section-label reveal">服务保障</div>
        <h2 class="section-title reveal">自用账号 · 便捷付款 · 人工支持</h2>
        <div class="trust-grid">
          <article class="trust-card reveal">
            <div class="trust-num">01</div>
            <h3>{policy.noPassword}</h3>
            <p>开通过程无需提供登录密码，减少信息暴露风险。</p>
          </article>
          <article class="trust-card reveal">
            <div class="trust-num">02</div>
            <h3>直充自用账号</h3>
            <p>会员开通到您的账号，不提供共享账号，账号归属不变。</p>
          </article>
          <article class="trust-card reveal">
            <div class="trust-num">03</div>
            <h3>人工客服支持</h3>
            <p>遇到支付或开通异常，可联系人工客服协助核验处理。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad section-soft" id="faq">
      <div class="container">
        <div class="section-label reveal">常见问题</div>
        <h2 class="section-title reveal">SuperGrok 代充常见问题</h2>
        <div class="faq-list">
          <div class="faq-item active">
            <div class="faq-q">国内怎么开通 SuperGrok？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              您可以选择月付或双月方案，通过{pay.label}付款，由露梦AI Store 协助将会员开通到您的自用账号，无需境外支付方式。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">Grok 一个月和两个月分别多少钱？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              当前月付价格为 ¥{g.monthly}，双月方案为 ¥{g.bimonthly}。选择双月相比连续购买两个月月付可节省 ¥{g.bimonthly_save}。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">开通时需要提供账号密码吗？<span class="faq-icon">+</span></div>
            <div class="faq-a">不需要提供登录密码。客服会按实际开通流程说明必要信息，减少敏感信息暴露。</div>
          </div>
          <div class="faq-item">
            <div class="faq-q">是共享账号还是自己的账号？<span class="faq-icon">+</span></div>
            <div class="faq-a">为您的自用账号开通对应会员周期，不提供多人共享账号，账号归属不变。</div>
          </div>
          <div class="faq-item">
            <div class="faq-q">为什么推荐双月方案？<span class="faq-icon">+</span></div>
            <div class="faq-a">
              双月方案一次开通两个月，更适合计划稳定使用的用户；同时相比月付可省 ¥{g.bimonthly_save}，续费更少更省心。
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-q">支持哪些付款方式？<span class="faq-icon">+</span></div>
            <div class="faq-a">{pay.faq}</div>
          </div>
          <div class="faq-item">
            <div class="faq-q">遇到开通异常怎么办？<span class="faq-icon">+</span></div>
            <div class="faq-a">可联系人工客服协助核验订单与账号状态；若无法完成开通，将按订单约定处理后续事宜。</div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-banner" id="contact">
      <div class="container">
        <div class="section-label">立即开始</div>
        <h2 class="section-title">选择套餐，安排 SuperGrok 开通</h2>
        <p class="section-sub">把您要开的周期和账号当前状态发给客服，确认后再付款。</p>
        <div class="hero-actions">
          <button class="pill" type="button" onclick="openQrModal()">添加微信</button>
          <a class="pill secondary" href="#plans">查看套餐</a>
        </div>
      </div>
    </section>
  </main>
</ProductLayout>
