---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<BaseLayout title="关于" description="关于露梦的博客">
  <section class="section-pad">
    <div class="container">
      <div class="page-head">
        <h1>关于</h1>
      </div>
      <div class="layout">
        <div class="content-main">
          <div class="prose">
            <p>你好，我是露梦。</p>
            <p>
              这是我的个人博客，用 <a href="https://astro.build/" target="_blank" rel="noopener">Astro</a>
              构建，后台使用 <a href="https://decapcms.org/" target="_blank" rel="noopener">Decap CMS</a>
              可视化写作，部署在 Cloudflare Pages 上。
            </p>
            <h2>这里写什么</h2>
            <p>主要记录 AI 工具、技术与日常思考。</p>
            <h2>写作后台</h2>
            <p>后台地址：<a href="/admin/">/admin/</a>（需要 GitHub 授权登录）。</p>
          </div>
        </div>
        <Sidebar />
      </div>
    </div>
  </section>
</BaseLayout>
