---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title="文章" description="全部文章列表">
  <section class="section-pad">
    <div class="container">
      <div class="page-head">
        <h1>文章</h1>
        <p>共 {posts.length} 篇</p>
      </div>
      <div class="layout">
        <div class="content-main">
          {posts.length > 0 ? (
            <ul class="post-list">
              {posts.map((post) => (
                <li>
                  <a class="post-card" href={`/blog/${post.id}/`}>
                    <h2 class="post-card-title">{post.data.title}</h2>
                    <div class="post-card-meta">{dateFmt.format(post.data.pubDate)}</div>
                    <p class="post-card-desc">{post.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p>还没有文章。</p>
          )}
        </div>
        <Sidebar />
      </div>
    </div>
  </section>
</BaseLayout>
